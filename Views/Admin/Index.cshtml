@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_AdminLayout";
}

<!-- Today's Quick Stats -->
<div class="row g-3 mb-4">
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 border-start border-primary border-4">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                    <i class="fas fa-users fa-lg text-primary"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold text-primary">@Model.TotalUsers</div>
                    <div class="text-muted small">Total Customers</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 border-start border-success border-4">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-success bg-opacity-10 p-3">
                    <i class="fas fa-box-open fa-lg text-success"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold text-success">@Model.TotalProducts</div>
                    <div class="text-muted small">Total Products</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 border-start border-warning border-4">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-warning bg-opacity-10 p-3">
                    <i class="fas fa-shopping-bag fa-lg text-warning"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold text-warning">@Model.TotalOrders</div>
                    <div class="text-muted small">Total Orders</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 border-start border-danger border-4">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-danger bg-opacity-10 p-3">
                    <i class="fas fa-rupee-sign fa-lg text-danger"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold text-danger">₹@Model.TotalSales.ToString("N0")</div>
                    <div class="text-muted small">Total Revenue</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Today's Stats Row -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-3 fw-bold text-success">@Model.TodayOrders</div>
            <div class="text-muted small">Today's Orders</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-3 fw-bold text-info">₹@Model.TodaySales.ToString("N0")</div>
            <div class="text-muted small">Today's Revenue</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <a asp-action="Orders" asp-route-status="Pending" class="text-decoration-none">
                <div class="fs-3 fw-bold text-warning">@Model.PendingOrders</div>
                <div class="text-muted small">Pending Orders</div>
            </a>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-3 fw-bold text-primary">@Model.DispatchedOrders</div>
            <div class="text-muted small">Dispatched</div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Revenue Chart -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-bold border-bottom d-flex justify-content-between align-items-center">
                <span><i class="fas fa-chart-bar text-success me-2"></i>Monthly Revenue – @DateTime.Now.Year</span>
                <a asp-action="Reports" asp-route-type="monthly" class="btn btn-outline-success btn-sm">
                    Full Report
                </a>
            </div>
            <div class="card-body">
                <canvas id="revenueChart" height="80"></canvas>
            </div>
        </div>
    </div>

    <!-- Order Status Donut -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white fw-bold border-bottom">
                <i class="fas fa-chart-pie text-primary me-2"></i>Order Status
            </div>
            <div class="card-body d-flex flex-column align-items-center justify-content-center">
                <canvas id="statusChart" height="200" style="max-width:220px"></canvas>
                <div class="mt-3 w-100">
                    <div class="d-flex justify-content-between small mb-1">
                        <span><span class="badge bg-warning me-1">&nbsp;</span>Pending</span>
                        <strong>@Model.PendingOrders</strong>
                    </div>
                    <div class="d-flex justify-content-between small mb-1">
                        <span><span class="badge bg-primary me-1">&nbsp;</span>Accepted</span>
                        <strong>@Model.AcceptedOrders</strong>
                    </div>
                    <div class="d-flex justify-content-between small mb-1">
                        <span><span class="badge bg-info me-1">&nbsp;</span>Dispatched</span>
                        <strong>@Model.DispatchedOrders</strong>
                    </div>
                    <div class="d-flex justify-content-between small mb-1">
                        <span><span class="badge bg-success me-1">&nbsp;</span>Delivered</span>
                        <strong>@Model.DeliveredOrders</strong>
                    </div>
                    <div class="d-flex justify-content-between small">
                        <span><span class="badge bg-danger me-1">&nbsp;</span>Cancelled</span>
                        <strong>@Model.CancelledOrders</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Top Selling Products -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-bold border-bottom d-flex justify-content-between align-items-center">
                <span><i class="fas fa-fire text-danger me-2"></i>Top Selling Products</span>
                <a asp-action="Reports" asp-route-type="product" class="btn btn-outline-secondary btn-sm">View All</a>
            </div>
            <div class="card-body p-0">
                @foreach (var (item, i) in Model.TopSellingProducts.Select((x, i) => (x, i + 1)))
                {
                    <div class="d-flex align-items-center gap-3 p-3 @(i < Model.TopSellingProducts.Count ? "border-bottom" : "")">
                        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white"
                             style="width:32px;height:32px;min-width:32px;font-size:0.8rem;
                                    background:@(i==1?"#f4a225":i==2?"#6c757d":i==3?"#cd7f32":"#2e7d32")">
                            @i
                        </div>
                        <div class="flex-grow-1">
                            <div class="fw-semibold small">@item.ProductName</div>
                            <small class="text-muted">@item.TotalQty units sold</small>
                        </div>
                        <div class="text-end">
                            <div class="fw-bold text-success small">₹@item.TotalRevenue.ToString("N0")</div>
                        </div>
                    </div>
                }
                @if (!Model.TopSellingProducts.Any())
                {
                    <p class="text-muted text-center py-3 small">No sales data yet.</p>
                }
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-bold border-bottom">
                <i class="fas fa-bolt text-warning me-2"></i>Quick Actions
            </div>
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-6">
                        <a asp-action="AddProduct" class="btn btn-success w-100 py-3">
                            <i class="fas fa-plus-circle d-block fs-4 mb-1"></i>
                            <small>Add Product</small>
                        </a>
                    </div>
                    <div class="col-6">
                        <a asp-action="AddCategory" class="btn btn-primary w-100 py-3">
                            <i class="fas fa-tags d-block fs-4 mb-1"></i>
                            <small>Add Category</small>
                        </a>
                    </div>
                    <div class="col-6">
                        <a asp-action="Orders" asp-route-status="Pending"
                           class="btn btn-warning w-100 py-3">
                            <i class="fas fa-clock d-block fs-4 mb-1"></i>
                            <small>Pending Orders</small>
                        </a>
                    </div>
                    <div class="col-6">
                        <a asp-action="Reports" class="btn btn-info text-white w-100 py-3">
                            <i class="fas fa-chart-bar d-block fs-4 mb-1"></i>
                            <small>Reports</small>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Recent Orders Table -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white fw-bold border-bottom d-flex justify-content-between align-items-center">
        <span><i class="fas fa-list text-success me-2"></i>Recent Orders</span>
        <a asp-action="Orders" class="btn btn-outline-success btn-sm">View All</a>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Order ID</th>
                    <th>Customer</th>
                    <th>Date</th>
                    <th>Items</th>
                    <th>Amount</th>
                    <th>Payment</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model.RecentOrders)
                {
                    <tr>
                        <td class="fw-bold">#@order.OrderId</td>
                        <td>
                            <div class="fw-semibold small">@order.User?.FullName</div>
                            <small class="text-muted">@order.User?.Email</small>
                        </td>
                        <td class="small text-muted">@order.OrderDate.ToString("dd MMM, hh:mm tt")</td>
                        <td class="small">@order.OrderDetails?.Count items</td>
                        <td class="fw-bold text-success">₹@order.GrandTotal.ToString("N0")</td>
                        <td><small>@order.PaymentMethod</small></td>
                        <td>
                            <span class="badge
                                @(order.Status == OrderStatus.Delivered  ? "bg-success" :
                                  order.Status == OrderStatus.Cancelled  ? "bg-danger"  :
                                  order.Status == OrderStatus.Rejected   ? "bg-dark"    :
                                  order.Status == OrderStatus.Dispatched ? "bg-info"    :
                                  order.Status == OrderStatus.Accepted   ? "bg-primary" : "bg-warning")">
                                @order.Status
                            </span>
                        </td>
                        <td>
                            <a asp-action="OrderDetails" asp-route-id="@order.OrderId"
                               class="btn btn-outline-secondary btn-sm">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    // ── Revenue Bar Chart ──
    const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    const salesData = @Html.Raw("[" + string.Join(",", Enumerable.Range(1, 12).Select(m => {
        var ms = Model.MonthlySalesData.FirstOrDefault(x => int.Parse(x.Month) == m);
        return ms?.Amount.ToString("F0") ?? "0";
    })) + "]");

    new Chart(document.getElementById('revenueChart'), {
        type: 'bar',
        data: {
            labels: months,
            datasets: [{
                label: 'Revenue (₹)',
                data: salesData,
                backgroundColor: 'rgba(46,125,50,0.75)',
                borderColor: '#2e7d32',
                borderWidth: 1,
                borderRadius: 5
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, ticks: { callback: v => '₹' + v.toLocaleString('en-IN') } }
            }
        }
    });

    // ── Order Status Donut Chart ──
    new Chart(document.getElementById('statusChart'), {
        type: 'doughnut',
        data: {
            labels: ['Pending','Accepted','Dispatched','Delivered','Cancelled'],
            datasets: [{
                data: [
                    @Model.PendingOrders,
                    @Model.AcceptedOrders,
                    @Model.DispatchedOrders,
                    @Model.DeliveredOrders,
                    @Model.CancelledOrders
                ],
                backgroundColor: ['#ffc107','#0d6efd','#0dcaf0','#198754','#dc3545'],
                borderWidth: 2
            }]
        },
        options: {
            cutout: '65%',
            plugins: {
                legend: { display: false }
            }
        }
    });
</script>
}
