@model ApnaKrishi.Models.ApplicationUser
@{
    ViewData["Title"] = "Customer Details";
    Layout = "_AdminLayout";
    var orders = ViewBag.Orders as List<ApnaKrishi.Models.Order> ?? new();
    decimal totalSpent = ViewBag.TotalSpent ?? 0m;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Customer Profile</h5>
    <a asp-action="Users" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left me-1"></i>Back to Users
    </a>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center p-4 mb-3">
            <div class="rounded-circle bg-success text-white d-flex align-items-center
                 justify-content-center mx-auto mb-3 fs-1 fw-bold"
                 style="width:80px;height:80px">
                @Model.FullName.Substring(0, 1).ToUpper()
            </div>
            <h5>@Model.FullName</h5>
            <div class="text-muted small">@Model.Email</div>
            <div class="text-muted small">@Model.Mobile</div>
            <div class="mt-2">
                <span class="badge @(Model.IsBlocked ? "bg-danger" : "bg-success") fs-6">
                    @(Model.IsBlocked ? "Blocked" : "Active")
                </span>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h6 class="fw-bold mb-3">Address</h6>
                <p class="text-muted small mb-0">
                    @(Model.Address ?? "–")<br />
                    @Model.City @(Model.State != null ? $", {Model.State}" : "") @(Model.PinCode != null ? $"– {Model.PinCode}" : "")
                </p>
            </div>
        </div>

        <div class="card border-0 shadow-sm mt-3">
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Total Orders</span>
                    <strong>@orders.Count</strong>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Total Spent</span>
                    <strong class="text-success">₹@totalSpent.ToString("N2")</strong>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-muted small">Registered</span>
                    <strong>@Model.CreatedDate.ToString("dd MMM yyyy")</strong>
                </div>
            </div>
        </div>

        <div class="mt-3 d-flex gap-2">
            <form asp-action="ToggleBlock" method="post" class="flex-fill">
                @Html.AntiForgeryToken()
                <input type="hidden" name="userId" value="@Model.Id" />
                <button type="submit"
                        class="btn w-100 @(Model.IsBlocked ? "btn-outline-success" : "btn-outline-warning")"
                        onclick="return confirm('@(Model.IsBlocked ? "Unblock" : "Block") this user?')">
                    <i class="fas @(Model.IsBlocked ? "fa-unlock" : "fa-ban") me-1"></i>
                    @(Model.IsBlocked ? "Unblock" : "Block")
                </button>
            </form>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-light fw-bold">
                Order History (@orders.Count orders)
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Order ID</th>
                            <th>Date</th>
                            <th>Amount</th>
                            <th>Payment</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!orders.Any())
                        {
                            <tr><td colspan="6" class="text-center text-muted py-3">No orders yet.</td></tr>
                        }
                        @foreach (var o in orders)
                        {
                            <tr>
                                <td class="fw-bold">#@o.OrderId</td>
                                <td class="small">@o.OrderDate.ToString("dd MMM yyyy")</td>
                                <td class="fw-bold text-success">₹@o.GrandTotal.ToString("F2")</td>
                                <td class="small">@o.PaymentMethod</td>
                                <td>
                                    <span class="badge
                                        @(o.Status == OrderStatus.Delivered  ? "bg-success" :
                                          o.Status == OrderStatus.Cancelled  ? "bg-danger"  :
                                          o.Status == OrderStatus.Dispatched ? "bg-info"    :
                                          o.Status == OrderStatus.Accepted   ? "bg-primary" : "bg-warning")">
                                        @o.Status
                                    </span>
                                </td>
                                <td>
                                    <a asp-action="OrderDetails" asp-route-id="@o.OrderId"
                                       class="btn btn-outline-secondary btn-sm">View</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
