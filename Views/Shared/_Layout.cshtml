<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Apna Krishi</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" type="image/x-icon" href="~/images/favicon.ico" />
</head>
<body>

<!-- Top Bar -->
<div class="bg-success text-white py-1 px-3 small d-none d-md-block">
    <div class="container d-flex justify-content-between">
        <span><i class="fas fa-phone me-1"></i> +91 9999999999 &nbsp;|&nbsp;
              <i class="fas fa-envelope me-1"></i> support@apnakrishi.com</span>
        <span>Free shipping on orders above ₹500</span>
    </div>
</div>

<!-- Main Navbar -->
<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top">
    <div class="container">
        <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
            <span style="font-size:1.8rem">🌾</span>
            <span class="fw-bold text-success fs-4">Apna Krishi</span>
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navMenu">
            <!-- Search -->
            <form class="d-flex mx-auto" style="width:35%" asp-controller="Product" asp-action="Index" method="get">
                <div class="input-group">
                    <input class="form-control" type="search" name="search" placeholder="Search products..."
                           value="@Context.Request.Query["search"]" />
                    <button class="btn btn-success" type="submit"><i class="fas fa-search"></i></button>
                </div>
            </form>

            <ul class="navbar-nav ms-auto align-items-center gap-1">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">
                        <i class="fas fa-home"></i> Home
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Product" asp-action="Index">
                        <i class="fas fa-seedling"></i> Products
                    </a>
                </li>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <!-- Cart -->
                    <li class="nav-item">
                        <a class="nav-link position-relative" asp-controller="Cart" asp-action="Index">
                            <i class="fas fa-shopping-cart fs-5"></i>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                                  id="cartBadge" style="font-size:0.6rem">0</span>
                        </a>
                    </li>

                    <!-- User Dropdown -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="fas fa-user-circle fs-5"></i> @User.Identity.Name?.Split('@')[0]
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" asp-controller="User" asp-action="Profile">
                                <i class="fas fa-user me-2"></i>My Profile</a></li>
                            <li><a class="dropdown-item" asp-controller="Order" asp-action="MyOrders">
                                <i class="fas fa-box me-2"></i>My Orders</a></li>
                            <li><a class="dropdown-item" asp-controller="User" asp-action="ChangePassword">
                                <i class="fas fa-key me-2"></i>Change Password</a></li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li><hr class="dropdown-divider"/></li>
                                <li><a class="dropdown-item text-danger" asp-controller="Admin" asp-action="Index">
                                    <i class="fas fa-cog me-2"></i>Admin Panel</a></li>
                            }
                            <li><hr class="dropdown-divider"/></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="fas fa-sign-out-alt me-2"></i>Logout
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="btn btn-outline-success btn-sm" asp-controller="Account" asp-action="Login">Login</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-success btn-sm" asp-controller="Account" asp-action="Register">Register</a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

<!-- Category Nav -->
<div class="bg-success d-none d-lg-block">
    <div class="container">
        <ul class="nav justify-content-center py-1">
            <li class="nav-item">
                <a class="nav-link text-white" asp-controller="Product" asp-action="Index" asp-route-categoryId="1">
                    <i class="fas fa-flask me-1"></i>Fertilizers
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-white" asp-controller="Product" asp-action="Index" asp-route-categoryId="2">
                    <i class="fas fa-seedling me-1"></i>Seeds
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-white" asp-controller="Product" asp-action="Index" asp-route-categoryId="3">
                    <i class="fas fa-bug me-1"></i>Pesticides
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-white" asp-controller="Product" asp-action="Index" asp-route-categoryId="4">
                    <i class="fas fa-tools me-1"></i>Farming Tools
                </a>
            </li>
        </ul>
    </div>
</div>

<!-- Alerts -->
<div class="container mt-2">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Info"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show">
            @TempData["Info"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
</div>

<main>
    @RenderBody()
</main>

<!-- Footer -->
<footer class="bg-dark text-white mt-5 pt-4 pb-3">
    <div class="container">
        <div class="row">
            <div class="col-md-4 mb-3">
                <h5 class="text-success">🌾 Apna Krishi</h5>
                <p class="small">Your trusted partner for quality agricultural products. Serving farmers across India.</p>
            </div>
            <div class="col-md-2 mb-3">
                <h6>Quick Links</h6>
                <ul class="list-unstyled small">
                    <li><a class="text-white-50" asp-controller="Home" asp-action="About">About Us</a></li>
                    <li><a class="text-white-50" asp-controller="Home" asp-action="Contact">Contact</a></li>
                    <li><a class="text-white-50" asp-controller="Home" asp-action="Privacy">Privacy Policy</a></li>
                </ul>
            </div>
            <div class="col-md-3 mb-3">
                <h6>Categories</h6>
                <ul class="list-unstyled small">
                    <li><a class="text-white-50" asp-controller="Product" asp-action="Index" asp-route-categoryId="1">Fertilizers</a></li>
                    <li><a class="text-white-50" asp-controller="Product" asp-action="Index" asp-route-categoryId="2">Seeds</a></li>
                    <li><a class="text-white-50" asp-controller="Product" asp-action="Index" asp-route-categoryId="3">Pesticides</a></li>
                    <li><a class="text-white-50" asp-controller="Product" asp-action="Index" asp-route-categoryId="4">Farming Tools</a></li>
                </ul>
            </div>
            <div class="col-md-3 mb-3">
                <h6>Contact</h6>
                <p class="small text-white-50">
                    <i class="fas fa-phone me-1"></i> +91 9999999999<br/>
                    <i class="fas fa-envelope me-1"></i> support@apnakrishi.com<br/>
                    <i class="fas fa-map-marker-alt me-1"></i> India
                </p>
            </div>
        </div>
        <hr class="border-secondary"/>
        <p class="text-center text-white-50 small mb-0">
            &copy; @DateTime.Now.Year Apna Krishi. All Rights Reserved.
        </p>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@if (User.Identity?.IsAuthenticated == true)
{
    <script>
        async function updateCartBadge() {
            try {
                const res = await fetch('/Cart/GetCartCount');
                const count = await res.json();
                document.getElementById('cartBadge').textContent = count;
            } catch {}
        }
        updateCartBadge();
    </script>
}

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
