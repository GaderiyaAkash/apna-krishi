@model ApnaKrishi.Models.Product

<div class="card product-card h-100 border-0 shadow-sm">
    <div class="position-relative overflow-hidden">
        @if (Model.DiscountPercent > 0)
        {
            <span class="badge bg-danger position-absolute top-0 start-0 m-2" style="z-index:1">
                @Model.DiscountPercent% OFF
            </span>
        }
        @if (Model.IsNewArrival)
        {
            <span class="badge bg-primary position-absolute top-0 end-0 m-2" style="z-index:1">New</span>
        }
        <a asp-controller="Product" asp-action="Details" asp-route-id="@Model.ProductId">
            <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/no-image.png" : Model.ImageUrl)"
                 class="card-img-top product-img"
                 alt="@Model.ProductName"
                 style="height:200px;object-fit:cover"
                 onerror="this.src='/images/no-image.png'" />
        </a>
    </div>
    <div class="card-body d-flex flex-column p-3">
        <small class="text-muted mb-1">@Model.Category?.CategoryName</small>
        <h6 class="card-title mb-1 fw-semibold">
            <a asp-controller="Product" asp-action="Details" asp-route-id="@Model.ProductId"
               class="text-dark text-decoration-none">@Model.ProductName</a>
        </h6>

        <!-- Rating Stars -->
        <div class="mb-2">
            @for (int i = 1; i <= 5; i++)
            {
                <i class="fas fa-star @(i <= Math.Round(Model.AverageRating) ? "text-warning" : "text-muted")" style="font-size:0.75rem"></i>
            }
            <small class="text-muted">(@Model.Reviews.Count)</small>
        </div>

        <div class="mt-auto">
            <div class="d-flex align-items-center gap-2 mb-2">
                <span class="fw-bold text-success fs-5">₹@Model.DiscountedPrice.ToString("F0")</span>
                @if (Model.DiscountPercent > 0)
                {
                    <span class="text-muted text-decoration-line-through small">₹@Model.Price.ToString("F0")</span>
                }
            </div>

            @if (Model.Stock > 0)
            {
                <form asp-controller="Cart" asp-action="AddToCart" method="post" class="d-grid">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@Model.ProductId" />
                    <input type="hidden" name="quantity" value="1" />
                    <button type="submit" class="btn btn-success btn-sm">
                        <i class="fas fa-cart-plus me-1"></i>Add to Cart
                    </button>
                </form>
            }
            else
            {
                <button class="btn btn-secondary btn-sm w-100" disabled>Out of Stock</button>
            }
        </div>
    </div>
</div>
