@model CheckoutViewModel
@{
    ViewData["Title"] = "Checkout";
}

<div class="container my-4">
    <h2 class="fw-bold mb-4"><i class="fas fa-lock text-success me-2"></i>Checkout</h2>

    <form asp-action="PlaceOrder" method="post">
        @Html.AntiForgeryToken()
        <div class="row g-4">

            <!-- Delivery Address -->
            <div class="col-lg-7">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-success text-white fw-bold">
                        <i class="fas fa-map-marker-alt me-2"></i>Delivery Address
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="DeliveryAddress" class="form-label fw-semibold"></label>
                            <textarea asp-for="DeliveryAddress" class="form-control" rows="2"
                                      placeholder="House/Flat no, Street, Area..."></textarea>
                            <span asp-validation-for="DeliveryAddress" class="text-danger small"></span>
                        </div>
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label asp-for="City" class="form-label fw-semibold"></label>
                                <input asp-for="City" class="form-control" placeholder="City" />
                                <span asp-validation-for="City" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="State" class="form-label fw-semibold"></label>
                                <input asp-for="State" class="form-control" placeholder="State" />
                                <span asp-validation-for="State" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="PinCode" class="form-label fw-semibold"></label>
                                <input asp-for="PinCode" class="form-control" placeholder="Pin Code" />
                                <span asp-validation-for="PinCode" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Payment Method -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-success text-white fw-bold">
                        <i class="fas fa-credit-card me-2"></i>Payment Method
                    </div>
                    <div class="card-body">
                        <div class="row g-2">
                            <div class="col-6">
                                <label class="payment-option d-flex align-items-center gap-2 border rounded p-2 cursor-pointer">
                                    <input type="radio" asp-for="PaymentMethod" value="CashOnDelivery" class="form-check-input" checked />
                                    <span>💵 Cash on Delivery</span>
                                </label>
                            </div>
                            <div class="col-6">
                                <label class="payment-option d-flex align-items-center gap-2 border rounded p-2">
                                    <input type="radio" asp-for="PaymentMethod" value="UPI" class="form-check-input" />
                                    <span>📱 UPI / QR</span>
                                </label>
                            </div>
                            <div class="col-6">
                                <label class="payment-option d-flex align-items-center gap-2 border rounded p-2">
                                    <input type="radio" asp-for="PaymentMethod" value="CreditCard" class="form-check-input" />
                                    <span>💳 Credit Card</span>
                                </label>
                            </div>
                            <div class="col-6">
                                <label class="payment-option d-flex align-items-center gap-2 border rounded p-2">
                                    <input type="radio" asp-for="PaymentMethod" value="DebitCard" class="form-check-input" />
                                    <span>💳 Debit Card</span>
                                </label>
                            </div>
                            <div class="col-6">
                                <label class="payment-option d-flex align-items-center gap-2 border rounded p-2">
                                    <input type="radio" asp-for="PaymentMethod" value="NetBanking" class="form-check-input" />
                                    <span>🏦 Net Banking</span>
                                </label>
                            </div>
                            <div class="col-6">
                                <label class="payment-option d-flex align-items-center gap-2 border rounded p-2">
                                    <input type="radio" asp-for="PaymentMethod" value="Razorpay" class="form-check-input" />
                                    <span>⚡ Razorpay</span>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Notes -->
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <label class="form-label fw-semibold">Order Notes (Optional)</label>
                        <textarea asp-for="Notes" class="form-control" rows="2"
                                  placeholder="Any special delivery instructions..."></textarea>
                    </div>
                </div>
            </div>

            <!-- Order Summary -->
            <div class="col-lg-5">
                <div class="card border-0 shadow-sm sticky-top" style="top:80px">
                    <div class="card-header bg-success text-white fw-bold">
                        <i class="fas fa-receipt me-2"></i>Order Summary
                    </div>
                    <div class="card-body p-0">
                        <div style="max-height:300px;overflow-y:auto">
                            @foreach (var item in Model.CartItems)
                            {
                                <div class="d-flex align-items-center gap-2 p-2 border-bottom">
                                    <img src="@(string.IsNullOrEmpty(item.Product?.ImageUrl) ? "/images/no-image.png" : item.Product.ImageUrl)"
                                         style="width:50px;height:50px;object-fit:contain" class="rounded" />
                                    <div class="flex-grow-1">
                                        <small class="fw-semibold d-block">@item.Product?.ProductName</small>
                                        <small class="text-muted">Qty: @item.Quantity</small>
                                    </div>
                                    <small class="fw-bold text-success">₹@item.TotalPrice.ToString("F2")</small>
                                </div>
                            }
                        </div>
                        <div class="p-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span>Subtotal</span>
                                <span>₹@Model.SubTotal.ToString("F2")</span>
                            </div>
                            <div class="d-flex justify-content-between mb-1">
                                <span>Shipping</span>
                                <span class="@(Model.ShippingCharges == 0 ? "text-success" : "")">
                                    @(Model.ShippingCharges == 0 ? "FREE" : $"₹{Model.ShippingCharges:F2}")
                                </span>
                            </div>
                            <hr />
                            <div class="d-flex justify-content-between fw-bold fs-5">
                                <span>Total</span>
                                <span class="text-success">₹@Model.GrandTotal.ToString("F2")</span>
                            </div>

                            <button type="submit" class="btn btn-success w-100 mt-3 py-2 fw-bold btn-lg">
                                <i class="fas fa-check-circle me-2"></i>Place Order
                            </button>
                            <a asp-controller="Cart" asp-action="Index"
                               class="btn btn-outline-secondary w-100 mt-2">
                                <i class="fas fa-arrow-left me-2"></i>Back to Cart
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
