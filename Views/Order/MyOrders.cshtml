@model List<ApnaKrishi.Models.Order>
@{
    ViewData["Title"] = "My Orders";
}

<div class="container my-4">
    <h2 class="fw-bold mb-4"><i class="fas fa-box text-success me-2"></i>My Orders</h2>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div style="font-size:5rem">📦</div>
            <h5 class="text-muted mt-3">No orders yet</h5>
            <a asp-controller="Product" asp-action="Index" class="btn btn-success mt-3">
                Start Shopping
            </a>
        </div>
    }
    else
    {
        @foreach (var order in Model)
        {
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header d-flex justify-content-between align-items-center bg-light">
                    <div>
                        <strong>Order #@order.OrderId</strong>
                        <span class="text-muted ms-3 small">@order.OrderDate.ToString("dd MMM yyyy, hh:mm tt")</span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge
                            @(order.Status == OrderStatus.Delivered ? "bg-success" :
                              order.Status == OrderStatus.Cancelled ? "bg-danger" :
                              order.Status == OrderStatus.Dispatched ? "bg-info" :
                              order.Status == OrderStatus.Accepted ? "bg-primary" : "bg-warning")
                            fs-6">
                            @order.Status
                        </span>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-8">
                            @foreach (var detail in order.OrderDetails.Take(3))
                            {
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <img src="@(string.IsNullOrEmpty(detail.Product?.ImageUrl) ? "/images/no-image.png" : detail.Product.ImageUrl)"
                                         style="width:45px;height:45px;object-fit:contain" class="rounded border" />
                                    <div>
                                        <small class="fw-semibold">@detail.Product?.ProductName</small><br />
                                        <small class="text-muted">Qty: @detail.Quantity × ₹@detail.Price.ToString("F2")</small>
                                    </div>
                                </div>
                            }
                            @if (order.OrderDetails.Count > 3)
                            {
                                <small class="text-muted">+@(order.OrderDetails.Count - 3) more items</small>
                            }
                        </div>
                        <div class="col-md-4 text-md-end">
                            <div class="fw-bold text-success fs-5 mb-1">₹@order.GrandTotal.ToString("F2")</div>
                            <small class="text-muted d-block mb-2">@order.PaymentMethod</small>

                            <div class="d-flex gap-2 justify-content-md-end flex-wrap">
                                <a asp-action="Details" asp-route-orderId="@order.OrderId"
                                   class="btn btn-outline-success btn-sm">
                                    <i class="fas fa-eye me-1"></i>Details
                                </a>
                                <a asp-action="DownloadInvoice" asp-route-orderId="@order.OrderId"
                                   class="btn btn-outline-secondary btn-sm">
                                    <i class="fas fa-download me-1"></i>Invoice
                                </a>
                                @if (order.Status == OrderStatus.Pending || order.Status == OrderStatus.Accepted)
                                {
                                    <form asp-action="Cancel" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="orderId" value="@order.OrderId" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm"
                                                onclick="return confirm('Cancel this order?')">
                                            <i class="fas fa-times me-1"></i>Cancel
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>
