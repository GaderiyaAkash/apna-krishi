@model ChangePasswordViewModel
@{ ViewData["Title"] = "Change Password"; }

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-success text-white fw-bold">
                    <i class="fas fa-key me-2"></i>Change Password
                </div>
                <div class="card-body p-4">
                    <form asp-action="ChangePassword" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label asp-for="CurrentPassword" class="form-label fw-semibold"></label>
                            <input asp-for="CurrentPassword" class="form-control" placeholder="Current password" />
                            <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label fw-semibold"></label>
                            <input asp-for="NewPassword" class="form-control" placeholder="New password (min 6 chars)" />
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="ConfirmNewPassword" class="form-label fw-semibold"></label>
                            <input asp-for="ConfirmNewPassword" class="form-control" placeholder="Confirm new password" />
                            <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                        </div>
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
                        <button type="submit" class="btn btn-success w-100">Update Password</button>
                    </form>
                    <div class="mt-3 text-center">
                        <a asp-action="Profile" class="text-muted small">← Back to Profile</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
